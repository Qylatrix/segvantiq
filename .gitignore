# .gitignore for SEGVANTIQ / Qylatrix

# ── Secrets & credentials (NEVER commit) ────────────────────────────────────
.streamlit/secrets.toml
.env
*.env

# ── Data & model files (too large for git) ──────────────────────────────────
data/
models/
*.pkl
*.csv
*.xlsx

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environments ─────────────────────────────────────────────────────
.venv/
venv/
env/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
